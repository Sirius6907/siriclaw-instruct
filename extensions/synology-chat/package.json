{
  "name": "@siriclaw-instruct/synology-chat",
  "version": "2026.3.8",
  "description": "Synology Chat channel plugin for siriclaw-instruct",
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "siriclaw-instruct": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to siriclaw-instruct with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@siriclaw-instruct/synology-chat",
      "localPath": "extensions/synology-chat",
      "defaultChoice": "npm"
    }
  }
}




